{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:scope-download-recursive",
    "fs:scope-appdata-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://aspisfile.com/*" },
        { "url": "https://staging.aspisfile.com/*" },
        { "url": "https://aspisfile-prod.s3.eu-north-1.amazonaws.com/*" },
        { "url": "https://aspisfile-dev.s3.eu-north-1.amazonaws.com/*" }
      ]
    }
  ]
}
