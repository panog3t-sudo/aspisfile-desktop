{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:scope-download-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://aspisfile.com/*" },
        { "url": "https://staging.aspisfile.com/*" }
      ]
    }
  ]
}
