#!/bin/bash
#
# Runs after the .pkg payload is installed. Best-effort move of the
# .pkg the user double-clicked into their Trash so they don't have to
# clean up their Downloads folder manually.
#
# Important: this is BEST-EFFORT only. macOS Tahoe (Darwin 25+)
# tightened TCC restrictions on user-data folders like ~/Downloads,
# and installd-spawned scripts can no longer move files there even as
# root unless Full Disk Access is granted. When it fails the .pkg just
# stays in Downloads — same friction as installing any other macOS
# app from outside the App Store. Acceptable.
#
# An earlier attempt (v1.7.3) added a Finder/AppleScript fallback for
# the TCC case; that triggered a "Installer wants to control Finder"
# permission prompt on first install that was scarier than the
# original problem. Reverted. Auto-trash is a nice-to-have, not a
# core feature.
#
# Apple-set env vars available here:
#   PACKAGE_PATH       — absolute path of the .pkg that ran this install
#   HOME / USER        — invoking user's home / username

set -u

PKG="${PACKAGE_PATH:-}"
if [ -n "$PKG" ] && [ -e "$PKG" ]; then
  TRASH="$HOME/.Trash"
  if [ -d "$TRASH" ]; then
    /bin/mv -f "$PKG" "$TRASH/" 2>/dev/null || true
  fi
fi

exit 0
