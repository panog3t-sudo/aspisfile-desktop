{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AspisFile Viewer",
  "version": "1.7.22",
  "identifier": "com.aspisfile.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AspisFile Viewer",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000 https://aspisfile.com https://*.supabase.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://localhost:3000; connect-src 'self' http://localhost:3000 https://aspisfile.com https://*.supabase.co wss://*.supabase.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["afs"],
        "name": "AspisFile Document",
        "description": "Secure AspisFile document",
        "mimeType": "application/x-aspisfile"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "AspisFile.entitlements",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 200 },
        "applicationFolderPosition": { "x": 480, "y": 200 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_PUBLIC_KEY_PLACEHOLDER",
      "endpoints": ["https://aspisfile.com/api/releases/{{target}}/{{current_version}}"],
      "dialog": false
    },
    "deep-link": {
      "desktop": {
        "schemes": ["aspisfile"]
      }
    }
  }
}
