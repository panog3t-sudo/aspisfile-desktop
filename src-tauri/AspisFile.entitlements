<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Associated Domains — tells macOS that this app is the legitimate
        client for aspisfile.com. Required for two things in the Tauri
        WebView whose origin is tauri://localhost:

        applinks:   Universal Link handling. iOS+macOS both rely on the
                    AASA file at https://<host>/.well-known/apple-app-
                    site-association.

        webcredentials:
                    WebAuthn RP authority. Without this, the WebView
                    rejects the server's rp.id=aspisfile.com with
                    NotAllowedError (visible to JS as "Passkey setup
                    was cancelled") because tauri://localhost is not a
                    registrable suffix of aspisfile.com. With this
                    entitlement, macOS treats the app as a trusted
                    client for that RP and accepts the credential
                    creation/use.

        AASA already lists 37M8KCP95L.com.aspisfile.viewer in both
        applinks.details and webcredentials.apps — see /public/.well-
        known/apple-app-site-association in the web repo.
    -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:aspisfile.com</string>
        <string>applinks:staging.aspisfile.com</string>
        <string>webcredentials:aspisfile.com</string>
        <string>webcredentials:staging.aspisfile.com</string>
    </array>
</dict>
</plist>
